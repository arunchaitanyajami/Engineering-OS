{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Engineering OS",
  "version": "0.1.0",
  "identifier": "ai.trae.engineeringos",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev:desktop-env",
    "beforeBuildCommand": "pnpm --dir ../.. build:desktop-runtime",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Engineering OS",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/engineering-os-node"],
    "resources": {
      "../../desktop-backend/dist/": "desktop-backend/"
    },
    "icon": []
  }
}
