{
  "name": "engineering-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop-first, AI-native engineering platform.",
  "packageManager": "pnpm@10.4.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:desktop": "pnpm --filter @engineering-os/desktop dev",
    "dev:web": "pnpm --filter @engineering-os/desktop dev:web",
    "dev:cli": "pnpm --filter @engineering-os/cli cli --help",
    "build:desktop": "pnpm --filter @engineering-os/desktop build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.config.ts --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "boundaries:check": "depcruise --config dependency-cruiser.cjs --include-only '^apps|^packages' .",
    "deps:check": "pnpm dedupe --check",
    "security:check": "pnpm audit --prod --audit-level high",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm boundaries:check && pnpm deps:check && pnpm build",
    "check:full": "pnpm check && pnpm security:check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "better-sqlite3": "^12.2.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.9",
    "zod": "^3.24.1"
  }
}
